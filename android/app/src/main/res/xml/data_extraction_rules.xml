<?xml version="1.0" encoding="utf-8"?>
<!--
  Reglas de Auto Backup / transferencia de dispositivo para Android 12+
  (referenciadas desde android:dataExtractionRules). Ver backup_rules.xml
  para la explicación — misma exclusión, formato nuevo de Android 12+, que
  además cubre el traspaso directo entre dispositivos (cable/Quick Share),
  no solo el backup a la nube.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="WeLiftTogether/feedback.json" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="WeLiftTogether/feedback.json" />
    </device-transfer>
</data-extraction-rules>
